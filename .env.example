# ===================================================
# CITTAA COMPETITOR INTEL — Environment Variables
# Copy this file to .env and fill in your values
# ===================================================

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://postgres:password@localhost:5432/cittaa_intel

# ---- REQUIRED ----
# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ---- EMAIL DIGEST ----
# Use Gmail App Password (not your Gmail password)
# Enable: Google Account → Security → 2FA → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sairam@cittaa.in
SMTP_PASSWORD=your_gmail_app_password_here
DIGEST_RECIPIENTS=sairam@cittaa.in

# ---- OPTIONAL (for richer data) ----
# Twitter/X Bearer Token — get from developer.twitter.com
TWITTER_BEARER_TOKEN=

# YouTube Data API v3 — get from console.cloud.google.com
YOUTUBE_API_KEY=

# ---- APP CONFIG ----
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-key
ALLOWED_ORIGINS=*
SCRAPE_INTERVAL_HOURS=6
GEMINI_MODEL=gemini-1.5-flash
