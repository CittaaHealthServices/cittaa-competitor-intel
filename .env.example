# ===================================================
# CITTAA COMPETITOR INTEL — Environment Variables
# These match your existing Railway shared variables
# ===================================================

# Database — IMPORTANT: Use POSTGRES_URL (not DATABASE_URL) to avoid collision
# with Railway's shared DATABASE_URL variable (which may be your MongoDB URI).
# When you add PostgreSQL in Railway, copy the connection URL and set it as POSTGRES_URL.
POSTGRES_URL=postgresql://postgres:password@localhost:5432/cittaa_intel

# ---- REQUIRED ----
# Google Gemini API Key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ---- EMAIL (uses your existing Railway shared variables) ----
RESEND_API_KEY=re_xxxxxxxxxxxx          # from resend.com → API Keys
RESEND_FROM_EMAIL=sairam@cittaa.in      # verified sender in Resend
RESEND_FROM_NAME=Cittaa Intel
ADMIN_EMAIL=sairam@cittaa.in            # digest recipient

# ---- OPTIONAL (for richer social data) ----
TWITTER_BEARER_TOKEN=                   # developer.twitter.com
YOUTUBE_API_KEY=                        # console.cloud.google.com

# ---- OPTIONAL (for deep Google web research) ----
# Gives richer results: press releases, funding news, product launches, interviews
# Step 1: Enable "Custom Search JSON API" at console.cloud.google.com
# Step 2: Create a Programmable Search Engine at programmablesearchengine.google.com
#         Set it to search the entire web. Copy the "Search engine ID" (cx).
GOOGLE_SEARCH_API_KEY=                  # same key as GEMINI or a separate Google API key
GOOGLE_SEARCH_CX=                       # Programmable Search Engine ID (e.g. 017576662512468239146:omuauf_lfve)

# ---- APP CONFIG ----
DEBUG=false
ALLOWED_ORIGINS=*
GEMINI_MODEL=gemini-2.5-pro
